{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiyoshi Music",
  "version": "0.9.14-beta",
  "identifier": "dev.kiyoshi.music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kiyoshi Music",
        "width": 1100,
        "height": 700,
        "minWidth": 960,
        "minHeight": 560,
        "fullscreen": false,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' ipc: http://ipc.localhost http://localhost:9847 http://127.0.0.1:9847 http://127.0.0.1:8888 https://translate.googleapis.com https://api.github.com; img-src 'self' data: https: http: blob:; media-src 'self' file: blob: https:; font-src 'self' data: https://fonts.gstatic.com; frame-src http://localhost:*"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFQTRFQzQzQjhFNEFCQTgKUldTb3ErUzRRK3lrL3RyNE1uWlpmMGtLVksyNXIzQjRpbVpTYXU5akZOYXI2NEJZaHpKY3Q4RzQK",
      "endpoints": [
        "https://raw.githubusercontent.com/KiyoshiTheDevil/kiyoshi-music/master/updates/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon_32.png", "icons/icon_128.png", "icons/icon_256.png", "icons/icon.ico"],
    "externalBin": [
      "binaries/kiyoshi-server"
    ],
    "linux": {
      "deb": {
        "depends": ["ffmpeg"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
