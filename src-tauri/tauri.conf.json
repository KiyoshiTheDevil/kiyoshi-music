{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiyoshi Music",
  "version": "0.9.2-alpha",
  "identifier": "dev.kiyoshi.music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kiyoshi Music",
        "width": 1100,
        "height": 700,
        "minWidth": 960,
        "minHeight": 560,
        "fullscreen": false,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon_32.png", "icons/icon_128.png", "icons/icon_256.png", "icons/icon.ico"],
    "externalBin": [
      "binaries/kiyoshi-server"
    ],
    "linux": {
      "deb": {
        "depends": ["ffmpeg"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
